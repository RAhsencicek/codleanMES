# Codlean MES — Ortam Değişkenleri Şablonu
# ═══════════════════════════════════════════════════════════════
# Bu dosya (.env.example) git'e girer — sadece şablon.
# Gerçek değerleri .env dosyasına kopyala (git'e GİTMEZ):
#
#   cp .env.example .env
#   # Sonra .env içindeki değerleri doldur
#
# Kullanım: Sistem başlatılmadan önce otomatik yüklenir.
# Tüm scriptler bu değerleri önce env var'dan, yoksa varsayılandan okur.
# ═══════════════════════════════════════════════════════════════

# ─── Kafka Bağlantı Ayarları ─────────────────────────────────────────────────
# Fabrika iç ağındaki Kafka broker adresi
# Üretim: VPN bağlı olduğundan emin ol
KAFKA_BOOTSTRAP_SERVERS=10.x.x.x:7001

# Tüm makine sensörlerinin aktığı Kafka topic adı
KAFKA_TOPIC=mqtt-topic-v2

# Consumer group kimliği — aynı group_id ile birden fazla tüketici
# çalışırsa Kafka mesajları aralarında böler (dikkat)
KAFKA_GROUP_ID=ariza-tahmin-pipeline

# ─── Google Gemini API (AI Usta Başı) ────────────────────────────────────────
# AI Usta Başı özelliği için gerekli.
# Anahtar alımı: https://aistudio.google.com/app/apikey
# Tanımlı değilse sistem sessizce devre dışı bırakır (graceful degradation).
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Sistem Konfigürasyonu ───────────────────────────────────────────────────
# Ana konfigürasyon dosyasının yolu (varsayılan: config/limits_config.yaml)
# Farklı ortamlar için (test, prod) ayrı config dosyaları kullanılabilir.
CONFIG_PATH=config/limits_config.yaml
